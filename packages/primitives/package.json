{
  "name": "@hope-ui/primitives",
  "version": "0.0.0",
  "description": "Internal behavior kernel for hope-ui (advanced/unstable escape hatch, not a stability-promised public API): composable SolidJS primitives for rendering, focus, dismissal, presence, and ARIA wiring",
  "license": "MIT",
  "type": "module",
  "sideEffects": false,
  "files": ["dist"],
  "hope": {
    "entries": {
      "calendar": "src/calendar/index.ts",
      "dialog": "src/dialog/index.ts",
      "listbox": "src/listbox/index.ts",
      "modal-backdrop": "src/modal-backdrop/index.ts",
      "internal": "src/internal/index.ts",
      "render": "src/render/index.ts",
      "utils": "src/utils/index.ts",
      "zag-solid": "src/zag-solid/index.ts"
    }
  },
  "exports": {
    "./calendar": {
      "types": "./dist/calendar/index.d.ts",
      "solid": "./dist/calendar/index.jsx"
    },
    "./dialog": {
      "types": "./dist/dialog/index.d.ts",
      "solid": "./dist/dialog/index.jsx"
    },
    "./listbox": {
      "types": "./dist/listbox/index.d.ts",
      "solid": "./dist/listbox/index.jsx"
    },
    "./modal-backdrop": {
      "types": "./dist/modal-backdrop/index.d.ts",
      "solid": "./dist/modal-backdrop/index.jsx"
    },
    "./internal": {
      "types": "./dist/internal/index.d.ts",
      "solid": "./dist/internal/index.jsx"
    },
    "./render": {
      "types": "./dist/render/index.d.ts",
      "solid": "./dist/render/index.jsx"
    },
    "./utils": {
      "types": "./dist/utils/index.d.ts",
      "solid": "./dist/utils/index.jsx"
    },
    "./zag-solid": {
      "types": "./dist/zag-solid/index.d.ts",
      "solid": "./dist/zag-solid/index.jsx"
    },
    "./package.json": "./package.json"
  },
  "scripts": {
    "build": "tsdown",
    "typecheck": "tsc --noEmit"
  },
  "peerDependencies": {
    "@solidjs/web": "catalog:",
    "@tanstack/virtual-core": "catalog:",
    "solid-js": "catalog:"
  },
  "peerDependenciesMeta": {
    "@tanstack/virtual-core": {
      "optional": true
    }
  },
  "dependencies": {
    "@hope-ui/i18n": "workspace:*",
    "@internationalized/date": "catalog:",
    "@solid-primitives/a11y": "catalog:",
    "@zag-js/core": "catalog:",
    "@zag-js/types": "catalog:",
    "@zag-js/utils": "catalog:"
  },
  "devDependencies": {
    "@hope-ui/internal-test-utils": "workspace:*",
    "@solidjs/web": "catalog:",
    "@tanstack/virtual-core": "catalog:",
    "solid-js": "catalog:"
  }
}
