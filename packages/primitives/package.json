{
  "name": "@solid-zero/primitives",
  "version": "0.0.0",
  "description": "Public behavior kernel for solid-zero: composable SolidJS primitives for rendering, focus, dismissal, presence, and ARIA wiring",
  "license": "MIT",
  "type": "module",
  "sideEffects": false,
  "files": ["dist"],
  "exports": {
    "./dialog": {
      "types": "./dist/dialog/index.d.ts",
      "import": "./dist/dialog/index.js"
    },
    "./modal-backdrop": {
      "types": "./dist/modal-backdrop/index.d.ts",
      "import": "./dist/modal-backdrop/index.js"
    },
    "./internal": {
      "types": "./dist/internal/index.d.ts",
      "import": "./dist/internal/index.js"
    },
    "./utils": {
      "types": "./dist/utils/index.d.ts",
      "import": "./dist/utils/index.js"
    },
    "./package.json": "./package.json"
  },
  "scripts": {
    "build": "vite build",
    "typecheck": "tsc --noEmit"
  },
  "peerDependencies": {
    "@solidjs/web": "catalog:",
    "solid-js": "catalog:"
  },
  "devDependencies": {
    "@solid-zero/internal-test-utils": "workspace:*",
    "@solidjs/web": "catalog:",
    "solid-js": "catalog:"
  }
}
