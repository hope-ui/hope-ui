{
  "name": "@enara-ui/components",
  "version": "0.0.0",
  "description": "Headless, accessible components for enara-ui — import per-component subpaths (e.g. @enara-ui/components/button)",
  "license": "MIT",
  "type": "module",
  "sideEffects": false,
  "files": ["dist"],
  "exports": {
    "./button": {
      "types": "./dist/button/index.d.ts",
      "import": "./dist/button/index.js"
    },
    "./dialog": {
      "types": "./dist/dialog/index.d.ts",
      "import": "./dist/dialog/index.js"
    },
    "./package.json": "./package.json"
  },
  "scripts": {
    "build": "vite build",
    "typecheck": "tsc --noEmit"
  },
  "peerDependencies": {
    "@solidjs/web": "catalog:",
    "solid-js": "catalog:"
  },
  "dependencies": {
    "@enara-ui/primitives": "workspace:*"
  },
  "devDependencies": {
    "@enara-ui/internal-test-utils": "workspace:*",
    "@solidjs/web": "catalog:",
    "solid-js": "catalog:"
  }
}
