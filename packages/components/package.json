{
  "name": "@hope-ui/components",
  "version": "0.0.0",
  "description": "Elegant, themeable, accessible components for hope-ui — import per-component subpaths (e.g. @hope-ui/components/button)",
  "license": "MIT",
  "type": "module",
  "sideEffects": false,
  "files": ["dist"],
  "hope": {
    "entries": {
      "badge": "src/badge/index.ts",
      "button": "src/button/index.ts",
      "calendar": "src/calendar/index.ts",
      "close-button": "src/close-button/index.ts",
      "dialog": "src/dialog/index.ts"
    }
  },
  "exports": {
    "./badge": {
      "types": "./dist/badge/index.d.ts",
      "solid": "./dist/badge/index.jsx"
    },
    "./button": {
      "types": "./dist/button/index.d.ts",
      "solid": "./dist/button/index.jsx"
    },
    "./calendar": {
      "types": "./dist/calendar/index.d.ts",
      "solid": "./dist/calendar/index.jsx"
    },
    "./close-button": {
      "types": "./dist/close-button/index.d.ts",
      "solid": "./dist/close-button/index.jsx"
    },
    "./dialog": {
      "types": "./dist/dialog/index.d.ts",
      "solid": "./dist/dialog/index.jsx"
    },
    "./package.json": "./package.json"
  },
  "scripts": {
    "build": "tsdown",
    "typecheck": "tsc --noEmit"
  },
  "peerDependencies": {
    "@solidjs/web": "catalog:",
    "solid-js": "catalog:"
  },
  "dependencies": {
    "@hope-ui/primitives": "workspace:*",
    "@hope-ui/theming": "workspace:*",
    "@internationalized/date": "catalog:"
  },
  "devDependencies": {
    "@hope-ui/internal-test-utils": "workspace:*",
    "@hope-ui/presets": "workspace:*",
    "@solidjs/web": "catalog:",
    "solid-js": "catalog:"
  }
}
