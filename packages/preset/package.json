{
  "name": "@hope-ui/preset",
  "version": "0.0.0",
  "description": "hope-ui Panda CSS preset — design tokens, semantic tokens, and component recipes (the hope-ui theme). Add to your panda.config.ts presets, then run panda codegen.",
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts"
    },
    "./package.json": "./package.json"
  },
  "files": ["src"],
  "sideEffects": false,
  "license": "MIT",
  "scripts": {
    "typecheck": "tsc --noEmit"
  },
  "peerDependencies": {
    "@pandacss/dev": ">=1.11.0"
  },
  "devDependencies": {
    "@pandacss/dev": "^1.11.4"
  }
}
