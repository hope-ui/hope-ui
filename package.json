{
  "name": "solid-zero",
  "version": "0.0.0",
  "private": true,
  "description": "Headless, accessible component library for SolidJS",
  "license": "MIT",
  "type": "module",
  "scripts": {
    "build": "turbo run build",
    "test": "vitest run --project=unit",
    "test:browser": "vitest run --project=browser",
    "lint": "biome check .",
    "format": "biome format --write .",
    "typecheck": "turbo run typecheck",
    "check:coverage-parity": "node scripts/check-coverage-parity.mjs",
    "check:dist-imports": "node scripts/check-dist-imports.mjs",
    "storybook": "storybook dev -p 6006",
    "build:storybook": "storybook build",
    "changeset": "changeset",
    "version-packages": "changeset version",
    "release": "turbo run build && changeset publish"
  },
  "devEngines": {
    "packageManager": {
      "name": "pnpm",
      "version": "^11.10.0",
      "onFail": "download"
    }
  },
  "devDependencies": {
    "@biomejs/biome": "2.5.3",
    "@changesets/cli": "2.31.0",
    "@playwright/test": "1.61.1",
    "@storybook/addon-a11y": "^10.5.0",
    "@storybook/addon-docs": "^10.5.0",
    "@vitest/browser": "4.1.10",
    "@vitest/browser-playwright": "4.1.10",
    "playwright": "1.61.1",
    "storybook": "^10.5.0",
    "storybook-solidjs-vite": "^10.6.0",
    "turbo": "2.10.4",
    "typescript": "5.9.3",
    "vite": "8.1.4",
    "vite-plugin-dts": "5.0.3",
    "vite-plugin-solid": "3.0.0-next.5",
    "vitest": "4.1.10"
  }
}
